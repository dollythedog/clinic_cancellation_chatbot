# ============================================================================
# Clinic Cancellation Chatbot — Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
#
# This file is the single source of truth for configuration keys. Every key
# below corresponds exactly to a field on the `Settings` class in
# app/infra/settings.py. If you add a new setting there, add it here too —
# the startup validation test enforces parity.
#
# Fields marked REQUIRED have no default. The application will refuse to
# start (loud failure via pydantic ValidationError) if any are missing.
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE (DATABASE_URL is REQUIRED)
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://username:password@localhost:5432/clinic_chatbot
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ----------------------------------------------------------------------------
# TWILIO (TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_PHONE_NUMBER are REQUIRED)
# ----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace_me
TWILIO_PHONE_NUMBER=+12145551234
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WEBHOOK_BASE_URL=
TWILIO_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# APPLICATION
# ----------------------------------------------------------------------------
BATCH_SIZE=3
HOLD_MINUTES=7
CONTACT_HOURS_START=08:00
CONTACT_HOURS_END=20:00
TIMEZONE=America/Chicago

# ----------------------------------------------------------------------------
# SECURITY
# ----------------------------------------------------------------------------
API_KEY=
JWT_SECRET=
WEBHOOK_SIGNATURE_ENABLED=true

# ----------------------------------------------------------------------------
# LOGGING
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=data/logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ----------------------------------------------------------------------------
# FASTAPI
# ----------------------------------------------------------------------------
APP_NAME=Clinic Cancellation Chatbot
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# ----------------------------------------------------------------------------
# STREAMLIT
# ----------------------------------------------------------------------------
STREAMLIT_SERVER_PORT=8501
# Bind to loopback by default. The dashboard login wrapper in
# dashboard/auth.py is the second layer; the first layer is "the
# dashboard isn't reachable from the LAN at all." Override to 0.0.0.0
# only when an upstream reverse proxy is filtering inbound traffic.
STREAMLIT_SERVER_ADDRESS=127.0.0.1
STREAMLIT_SERVER_HEADLESS=true

# ----------------------------------------------------------------------------
# DASHBOARD AUTHENTICATION (ALL THREE REQUIRED)
# ----------------------------------------------------------------------------
# The Streamlit dashboard gates access behind a single admin credential.
# Generation + rotation procedure is documented in DECISIONS.md under
# the 2026-04-23 entry "Streamlit dashboard authentication". TL;DR: run
# the documented Python one-liner once per install, paste the two
# printed values into this file, restart the NSSM Streamlit service.
# Rotate every 90 days or on any suspected compromise.
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD_HASH=
DASHBOARD_PASSWORD_SALT=

# ----------------------------------------------------------------------------
# DATA RETENTION
# ----------------------------------------------------------------------------
MESSAGE_BODY_RETENTION_DAYS=90
WAITLIST_RETENTION_DAYS=180

# ----------------------------------------------------------------------------
# RATE LIMITING
# ----------------------------------------------------------------------------
MAX_SMS_PER_HOUR=100
API_RATE_LIMIT=60

# ----------------------------------------------------------------------------
# SCHEDULER
# ----------------------------------------------------------------------------
HOLD_TIMER_CHECK_INTERVAL=30
PRIORITY_RECALC_INTERVAL=60

# ----------------------------------------------------------------------------
# MONITORING (all optional)
# ----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=
ALERT_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# ----------------------------------------------------------------------------
# EXTERNAL INTEGRATIONS (future / optional)
# ----------------------------------------------------------------------------
GREENWAY_API_URL=
GREENWAY_API_KEY=
PROVIDER_DB_URL=

# ----------------------------------------------------------------------------
# FEATURE FLAGS
# ----------------------------------------------------------------------------
ENABLE_SMS_SENDING=true
ENABLE_WEBHOOKS=true
ENABLE_AUTO_CONFIRMATION=true
ENABLE_PRIORITY_RECALC=true

# ----------------------------------------------------------------------------
# DEVELOPMENT
# ----------------------------------------------------------------------------
USE_MOCK_TWILIO=false
SEED_TEST_DATA=false
